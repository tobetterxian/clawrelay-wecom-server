# ============================================
# ClawRelay API Service Configuration
# ============================================
# This file configures environment variables for clawrelay-api service
# Copy to api-service.env and edit, then run manage-service.bat (option 8) to apply

# Claude CLI Path (required)
# Location of claude.exe binary
CLAUDE_BIN_PATH=C:\Users\Administrator\.local\bin

# Third-party API Configuration (optional)
# Leave empty to use official Claude API
# Set these to use a third-party OpenAI-compatible API
ANTHROPIC_AUTH_TOKEN=your_api_key_here
ANTHROPIC_BASE_URL=https://your-api-endpoint.com
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# Additional Environment Variables (optional)
# Add any other environment variables needed by Claude CLI
# Format: KEY=VALUE (one per line)
