# ============================================
# ClawRelay WeCom Server - Bot Configuration
# ============================================
# Copy this file and fill in your bot credentials.
# Each bot connects to WeChat Work via WebSocket.

bots:
  # ========================================
  # Claude Code 机器人（通过 clawrelay-api）
  # ========================================
  default:
    # [Required] Enterprise WeChat bot credentials
    bot_id: "YOUR_BOT_ID"
    secret: "YOUR_BOT_SECRET"

    # [Required] Bot type: claude_code | gemini | openai | codex | codex_cli
    bot_type: "claude_code"

    # [Required] ClawRelay API endpoint
    # Local: http://localhost:50009
    # Docker: http://host.docker.internal:50009
    relay_url: "http://localhost:50009"

    # [Optional] Bot display name (used to filter @mentions in group chat)
    name: "AI Assistant"

    # [Optional] Description
    description: "Default AI assistant"

    # [Optional] Claude working directory
    working_dir: ""

    # [Optional] Model name (default: claude-sonnet-4-6)
    model: ""

    # [Optional] System prompt
    system_prompt: ""

    # [Optional] User whitelist (empty = no restriction)
    # allowed_users:
    #   - "user_id_1"
    #   - "user_id_2"

    # [Optional] Environment variables injected into Claude subprocess
    # env_vars:
    #   MY_API_KEY: "xxx"

    # [Optional] Custom command modules
    # custom_commands:
    #   - "src.handlers.custom.my_commands"

  # ========================================
  # Gemini 机器人（直接调用 API）
  # ========================================
  # gemini_bot:
  #   bot_id: "YOUR_GEMINI_BOT_ID"
  #   secret: "YOUR_GEMINI_BOT_SECRET"
  #   bot_type: "gemini"
  #   name: "Gemini Assistant"
  #   description: "Gemini chat bot"
  #   # 模型名称（留空则自动选择最佳可用模型）
  #   # 可选: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
  #   model: ""  # 留空自动选择，或指定具体模型
  #   system_prompt: "你是一个友好的AI助手。"
  #   provider_config:
  #     api_key: "YOUR_GEMINI_API_KEY"
  #     enable_search: false  # 设置为 true 启用 Google Search 联网功能（需要 v1beta API）

  # ========================================
  # OpenAI 机器人（直接调用 API）
  # ========================================
  # openai_bot:
  #   bot_id: "YOUR_OPENAI_BOT_ID"
  #   secret: "YOUR_OPENAI_BOT_SECRET"
  #   bot_type: "openai"
  #   name: "GPT Assistant"
  #   description: "OpenAI GPT chat bot"
  #   model: ""  # 留空自动选择，或指定如 gpt-4o
  #   system_prompt: "You are a helpful AI assistant."
  #   provider_config:
  #     api_key: "YOUR_OPENAI_API_KEY"
  #     base_url: "https://api.openai.com/v1"  # 可选，用于自定义端点或第三方兼容服务

  # ========================================
  # Codex 机器人（通过 OpenAI Responses API）
  # ========================================
  # codex_bot:
  #   bot_id: "YOUR_CODEX_BOT_ID"
  #   secret: "YOUR_CODEX_BOT_SECRET"
  #   bot_type: "codex"
  #   name: "Codex Assistant"
  #   description: "OpenAI Codex coding bot"
  #   model: ""  # 留空默认使用 gpt-5.3-codex
  #   system_prompt: "你是一个擅长代码分析和实现的 AI 助手。"
  #   provider_config:
  #     api_key: "YOUR_OPENAI_API_KEY"
  #     base_url: "https://api.openai.com/v1"
  #     reasoning_effort: "medium"  # 可选: low | medium | high

  # ========================================
  # Codex CLI 机器人（直接调用本地 codex CLI）
  # ========================================
  # codex_cli_bot:
  #   bot_id: "YOUR_CODEX_CLI_BOT_ID"
  #   secret: "YOUR_CODEX_CLI_BOT_SECRET"
  #   bot_type: "codex_cli"
  #   name: "Codex CLI"
  #   description: "Local Codex CLI coding bot"
  #   working_dir: "/path/to/project"  # 必填，默认项目源目录 / 兼容旧配置入口
  #   model: ""  # 留空默认使用 gpt-5.3-codex
  #   system_prompt: "你是一个擅长本地代码修改与排障的 AI 助手。"
  #   env_vars:
  #     OPENAI_API_KEY: "YOUR_OPENAI_API_KEY"
  #   provider_config:
  #     codex_path: "/home/youruser/.nvm/versions/node/v20.20.1/bin/codex"
  #     sandbox_mode: "workspace-write"   # 可选: read-only | workspace-write
  #     skip_git_repo_check: false
  #     approval_policy: "on-request"      # 可选: untrusted | on-request | on-failure | never
  #     dangerously_bypass_approvals_and_sandbox: false  # 仅可信环境建议开启
  #     workspace_root: "/path/to/project/.codex_data"  # 可选，默认 <working_dir>/.codex_data
  #     codex_home: "/path/to/shared/codex-home"  # 可选，作为 Codex 运行 HOME；实际配置会落到其下的 .codex/
  #     default_workspace_init_mode: "empty"  # 可选: empty | git_remote | legacy_copy
  #     workspace_strategy: "copy"            # 兼容旧配置，等价于 legacy_copy
  #     default_group_workspace_mode: "personal"  # 可选: personal | shared
  #     session_timeout_seconds: 7200
  #     enable_project_workspace_mode: true
  #     # add_dirs:
  #     #   - "/another/writable/path"
  #     # profile: "default"

  # ========================================
  # Claude 机器人（通过第三方 API）
  # ========================================
  # claude_api_bot:
  #   bot_id: "YOUR_CLAUDE_BOT_ID"
  #   secret: "YOUR_CLAUDE_BOT_SECRET"
  #   bot_type: "openai"  # 使用 openai 类型，因为很多服务兼容 OpenAI 格式
  #   name: "Claude API"
  #   description: "Claude via third-party API"
  #   model: ""  # 留空自动选择最佳可用模型
  #   system_prompt: "You are Claude, a helpful AI assistant."
  #   provider_config:
  #     api_key: "YOUR_API_KEY"
  #     base_url: "https://your-api-endpoint.com/v1"  # 第三方 API 端点
