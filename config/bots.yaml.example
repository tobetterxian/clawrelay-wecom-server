# ============================================
# ClawRelay WeCom Server - Bot Configuration
# ============================================
# Copy this file and fill in your bot credentials.
# Each bot connects to WeChat Work via WebSocket.

bots:
  # ========================================
  # Claude Code 机器人（通过 clawrelay-api）
  # ========================================
  default:
    # [Required] Enterprise WeChat bot credentials
    # Docker 推荐直接放到 .env，再由这里读取
    bot_id: "${WECOM_BOT_ID}"
    secret: "${WECOM_BOT_SECRET}"

    # [Required] Bot type: claude_code | gemini | openai | codex | codex_cli
    bot_type: "claude_code"

    # [Required] ClawRelay API endpoint
    # Local: http://localhost:50009
    # Docker: http://host.docker.internal:50009
    relay_url: "${CLAUDE_RELAY_URL:-http://host.docker.internal:50009}"

    # [Optional] Bot display name (used to filter @mentions in group chat)
    name: "AI Assistant"

    # [Optional] Description
    description: "Default AI assistant"

    # [Optional] Claude working directory
    working_dir: ""

    # [Optional] Model name (default: claude-sonnet-4-6)
    model: ""

    # [Optional] System prompt
    system_prompt: ""

    # [Optional] User whitelist (empty = no restriction)
    # allowed_users:
    #   - "user_id_1"
    #   - "user_id_2"

    # [Optional] Environment variables injected into Claude subprocess
    # env_vars:
    #   MY_API_KEY: "xxx"

    # [Optional] Custom command modules
    # custom_commands:
    #   - "src.handlers.custom.my_commands"

  # ========================================
  # Gemini 机器人（直接调用 API）
  # ========================================
  # gemini_bot:
  #   bot_id: "YOUR_GEMINI_BOT_ID"
  #   secret: "YOUR_GEMINI_BOT_SECRET"
  #   bot_type: "gemini"
  #   name: "Gemini Assistant"
  #   description: "Gemini chat bot"
  #   # 模型名称（留空则自动选择最佳可用模型）
  #   # 可选: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
  #   model: ""  # 留空自动选择，或指定具体模型
  #   system_prompt: "你是一个友好的AI助手。"
  #   provider_config:
  #     api_key: "${GEMINI_API_KEY}"
  #     enable_search: false  # 设置为 true 启用 Google Search 联网功能（需要 v1beta API）
  #     inherit_group_project_context: true  # 群聊时自动继承 codex_cli 当前群项目上下文
  #     # group_project_context_bot_key: "codex_cli_bot"  # 可选：固定从某个 codex_cli 机器人读取群项目
  #     # group_project_context_workspace_root: "${WORKSPACE_ROOT_BASE:-/data/workspaces}/codex"  # 可选：显式指定项目状态目录

  # ========================================
  # 产品画册机器人（推荐：Gemini / OpenAI）
  # ========================================
  # brochure_bot:
  #   bot_id: "YOUR_BROCHURE_BOT_ID"
  #   secret: "YOUR_BROCHURE_BOT_SECRET"
  #   bot_type: "gemini"
  #   name: "产品画册"
  #   description: "产品画册策划与文案机器人"
  #   model: ""
  #   system_prompt: |
  #     你是一个专门负责产品画册策划的 AI 助手。
  #     你的职责是把用户提供的产品资料、图片、参数、案例整理成适合销售和市场使用的产品画册方案。
  #     输出时优先给出：
  #     1. 画册定位与目标受众
  #     2. 目录结构
  #     3. 每页标题与文案
  #     4. 配图建议
  #     5. 版式建议
  #     6. 如有必要，补充 H5 / 宣传页落地建议
  #   provider_config:
  #     api_key: "${GEMINI_API_KEY}"
  #     inherit_group_project_context: true  # 群聊时自动继承 codex_cli 当前群项目上下文
  #     enable_brochure_internal_delegate: true  # 允许“做完整画册”时后台自动委托给 codex_cli 落地
  #     delegate_execution_bot_key: "cx_bot"  # 可选：指定负责真正落地执行的 codex_cli 机器人
  #     # group_project_context_bot_key: "codex_cli_bot"
  #     # group_project_context_workspace_root: "${WORKSPACE_ROOT_BASE:-/data/workspaces}/codex"

