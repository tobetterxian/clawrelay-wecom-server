# ============================================
# ClawRelay WeCom Server - Environment Variables
# ============================================
# Copy this file to .env and modify as needed.
# `config/bots.yaml` supports `${VAR}` and `${VAR:-default}` placeholders.

# Bot config path
BOT_CONFIG_PATH=/app/config/bots.yaml

# Log directory
CHAT_LOG_DIR=/app/logs

# Workspace / CLI home
WORKSPACE_ROOT_BASE=/data/workspaces
CODEX_HOME_BASE=/data/codex-home
CLAUDE_HOME_BASE=/data/claude-home
CODEX_NPM_PACKAGE=@openai/codex

# Default enabled bot in config/bots.yaml.example
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# Optional model API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional API endpoint overrides
OPENAI_BASE_URL=https://api.openai.com/v1
CLAUDE_RELAY_URL=http://host.docker.internal:50009

# Optional GitHub access
GH_TOKEN=
GITHUB_TOKEN_CUSTOM=
GITHUB_REPO_SSH_URL=
# Example:
# ssh -i /run/local-secrets/github_id_ed25519 -o StrictHostKeyChecking=yes -o UserKnownHostsFile=/run/local-secrets/github_known_hosts
GIT_SSH_COMMAND=

# Optional Cloudflare (prefer CI/CD for production)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# AI / WeCom runtime tuning
WEIXIN_ENABLE_THINKING=true
WEIXIN_AGENT_TIMEOUT_SECONDS=30
WEIXIN_MAX_FILE_SIZE=20971520
