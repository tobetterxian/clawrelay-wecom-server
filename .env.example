# ============================================
# ClawRelay WeCom Server - Environment Variables
# ============================================
# Copy this file to .env and modify as needed.

# Bot config file path (default: config/bots.yaml)
# BOT_CONFIG_PATH=config/bots.yaml

# Chat log directory (default: logs)
# CHAT_LOG_DIR=logs

# AI Configuration
# WEIXIN_ENABLE_THINKING=true
# WEIXIN_AGENT_TIMEOUT_SECONDS=30

# File Upload
# WEIXIN_MAX_FILE_SIZE=20971520  # 20MB default
